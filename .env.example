NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Data mode: memory or supabase
APP_DATA_MODE=memory
ALLOW_MEMORY_MODE_IN_PRODUCTION=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional direct Postgres connection if your workflow needs it
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# Admin route protection
ADMIN_AUTH_SECRET=replace-with-a-long-random-secret-at-least-24-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
CRON_SECRET=replace-with-a-separate-random-secret-for-scheduled-scans
# Optional outbound ops alert webhook (Slack/Discord-style JSON endpoint).
# Disabled when unset. Payloads include source ids, states, counts, and timestamps only.
ALERT_WEBHOOK_URL=
# Queue-only scan route mode (T-RT2A) — optional. When true, admin/cron scan
# routes enqueue jobs but do not inline-drain them; rely on the dedicated worker.
SCAN_JOB_ROUTE_ENQUEUE_ONLY=false
# Dedicated scan worker loop. The worker drains queued jobs and, by default,
# self-enqueues the central EU/US/International monitoring schedule every 15m.
# Scheduled mode is for finite GitHub Actions runs; it exits after one empty
# cycle. Its expected interval must match the workflow schedule for health.
SCAN_JOB_WORKER_MODE=scheduled
SCAN_JOB_WORKER_EXPECTED_INTERVAL_MS=900000
SCAN_JOB_WORKER_ENABLE_SCHEDULER=true
SCAN_JOB_WORKER_SCHEDULER_INTERVAL_MS=900000
SCAN_JOB_WORKER_POLL_MS=30000
SCAN_JOB_WORKER_MAX_JOBS_PER_CYCLE=5

# Rate limiting (F6) — optional. When both are set, the scan API uses Upstash
# Redis for distributed rate limiting across serverless instances; otherwise it
# falls back to a per-instance in-memory limiter. Create a free Upstash Redis
# database and copy its REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Legifrance via official DILA/PISTE API (T-RT3B) — optional. When both are set,
# the 'legifrance' API connector can replace Cloudflare-blocked scraping. Obtain
# an OAuth2 client_id/secret by enrolling the app on PISTE (piste.gouv.fr) and
# subscribing to the DILA Légifrance API. Without them, Legifrance degrades
# honestly to the scraping parser.
LEGIFRANCE_PISTE_CLIENT_ID=
LEGIFRANCE_PISTE_CLIENT_SECRET=

# Legal-news / case-law API acceleration. Optional: agents degrade to RSS/static
# sources when absent, but these improve speed and source coverage.
# NewsAPI is discovery-only; do not treat it as an official legal database source.
NEWSAPI_API_KEY=
# Judilibre strengthens French official case-law monitoring. It can use a direct
# KeyId when available, or fall back to the PISTE OAuth credentials above.
JUDILIBRE_API_KEYID=
# Legal Data Hunter / legal-research MCP acceleration for multi-jurisdiction legal data.
LEGAL_DATA_HUNTER_MCP_URL=
LEGAL_DATA_HUNTER_API_KEY=
# US case-law / docket acceleration.
COURTLISTENER_API_KEY=
# Alias accepted if the credential is copied/stored as a token.
COURTLISTENER_API_TOKEN=

# EUR-Lex official SOAP webservice. Optional official EU legal database search
# acceleration; do not commit real credentials.
EURLEX_USERNAME=
EURLEX_PASSWORD=

# OpenAI
# Default: disabled. Keep disabled unless you intentionally want limited live processing.
AI_ENABLE_PROCESSING=false
# Safe one-item smoke test example:
# AI_ENABLE_PROCESSING=true
# AI_MAX_ITEMS_PER_SCAN=1
# AI_MONTHLY_BUDGET_USD=5
# AI_MAX_INPUT_TOKENS_PER_ITEM=6000
# Backward-compatible alias if needed:
AI_PROCESSING_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Approximate monthly ceiling for live AI processing
AI_MONTHLY_BUDGET_USD=20
# Hard per-item cap used before any live AI call
AI_MAX_INPUT_TOKENS_PER_ITEM=12000
# Hard per-scan cap for live AI processing
AI_MAX_ITEMS_PER_SCAN=10
AI_MODEL_RELEVANCE=gpt-5.4-nano
AI_MODEL_CLASSIFICATION=gpt-5.4-nano
AI_MODEL_SUMMARY=gpt-5.4-mini
AI_MODEL_DEEP_ANALYSIS=gpt-5.4
AI_COST_GUARDRAILS_ENABLED=true
