NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Data mode: memory or supabase
APP_DATA_MODE=memory
ALLOW_MEMORY_MODE_IN_PRODUCTION=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional direct Postgres connection if your workflow needs it
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres

# Admin route protection
ADMIN_AUTH_SECRET=replace-with-a-long-random-secret-at-least-24-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
CRON_SECRET=replace-with-a-separate-random-secret-for-scheduled-scans

# Rate limiting (F6) — optional. When both are set, the scan API uses Upstash
# Redis for distributed rate limiting across serverless instances; otherwise it
# falls back to a per-instance in-memory limiter. Create a free Upstash Redis
# database and copy its REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI
# Default: disabled. Keep disabled unless you intentionally want limited live processing.
AI_ENABLE_PROCESSING=false
# Safe one-item smoke test example:
# AI_ENABLE_PROCESSING=true
# AI_MAX_ITEMS_PER_SCAN=1
# AI_MONTHLY_BUDGET_USD=5
# AI_MAX_INPUT_TOKENS_PER_ITEM=6000
# Backward-compatible alias if needed:
AI_PROCESSING_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Approximate monthly ceiling for live AI processing
AI_MONTHLY_BUDGET_USD=20
# Hard per-item cap used before any live AI call
AI_MAX_INPUT_TOKENS_PER_ITEM=12000
# Hard per-scan cap for live AI processing
AI_MAX_ITEMS_PER_SCAN=10
AI_MODEL_RELEVANCE=gpt-5.4-nano
AI_MODEL_CLASSIFICATION=gpt-5.4-nano
AI_MODEL_SUMMARY=gpt-5.4-mini
AI_MODEL_DEEP_ANALYSIS=gpt-5.4
AI_COST_GUARDRAILS_ENABLED=true
