# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright e2e
/test-results
/playwright-report
/playwright/.cache
/e2e/__screenshots__

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# agent harness traces (local debugging artifacts)
.agent-traces/

# dev artifacts and local logs
*.log
.codex-*
.tmp-*
.runtime/
.codex-previews*
.next-*.log
.next-*.err.log

# env files (can opt-in for committing if needed)
.env*
# ...but the placeholder template is meant to be tracked
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AI coding-agent local config + reinstallable skill bundles
# (skills reinstall via `npx skills add` / `npx impeccable update`; some bundle
#  large binary assets, so we track the manifest/agent/config, not the cache)
.claude/settings.local.json
.claude/skills/
.agents/
.github/skills/
references/awesome-design-md/

# Graphify knowledge graph (generated artifact)
graphify-out/
graphify-build.log

# LLM Council (standalone tool, Karpathy) — not part of the site
tools/llm-council/
